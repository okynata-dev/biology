# Metadata JSON — short cache so mutations can refresh quickly (Phase 2)
# CORS open so OpenSea / marketplaces / explorers can fetch.
/metadata/*
  Cache-Control: public, max-age=300, s-maxage=300
  Access-Control-Allow-Origin: *

# Token PNGs / thumbs — immutable, cache forever.
# Thumbs (pngs/thumb/*) are 600×600 WebP+PNG, served by Pages directly.
# Masters (pngs/preview/*) are 3000×3000 PNGs, served by R2.
/pngs/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Engine — cache for a day, then revalidate
/specimen-engine.js
  Cache-Control: public, max-age=86400, must-revalidate

# Nav-wallet shared chrome (CSS+JS) — cache day, revalidate.
# Version-bust via ?v= query param when contents change.
/nav-wallet.css
  Cache-Control: public, max-age=86400, must-revalidate
/nav-wallet.js
  Cache-Control: public, max-age=86400, must-revalidate

# HTML — cache for an hour
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

# 404 explicitly NOT cached — without this, /*.html catches /404.html
# with a 1-hour cache, which means after a redeploy that adds a new
# real page, the CDN may keep serving the old 404 for legitimate URLs.
# `must-revalidate` forces the CDN to ask the origin every time.
/404.html
  Cache-Control: no-cache, must-revalidate
/404
  Cache-Control: no-cache, must-revalidate

# Admin panel — never cached, never indexed, never framed.
# Token lives in localStorage + URL hash, not in headers or logs.
/admin
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/admin.html
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY

# Static brand assets
/og-image.png
  Cache-Control: public, max-age=86400

/favicon.svg
  Cache-Control: public, max-age=604800

/favicon-dark.svg
  Cache-Control: public, max-age=604800

/sitemap.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=86400
