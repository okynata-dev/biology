# Cloudflare Pages — HTTP headers
# https://developers.cloudflare.com/pages/configuration/headers/
#
# Frame-embedding policy:
#   preview.html + rare-*.html ARE the NFT animation_url targets —
#     OpenSea and other marketplaces must iframe them from any origin,
#     so frame-ancestors stays open there.
#   Everything else (lab.html, index.html, make.html, explore.html)
#     hosts wallet flows + user input → frame-ancestors 'none' so
#     attacker sites can't overlay an invisible "Connect → Sign"
#     clickjack sequence on top of our buttons.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# Lab + landing + make + explore — no third-party framing allowed.
# Listed individually so the per-path rule wins over the wildcard.
/
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/index.html
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/lab.html
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/make.html
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/explore.html
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/manifesto.html
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/404.html
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY

# Metadata JSON — short cache so mutations can refresh quickly (Phase 2)
# CORS open so OpenSea / marketplaces / explorers can fetch.
/metadata/*
  Cache-Control: public, max-age=300, s-maxage=300
  Access-Control-Allow-Origin: *

# Token PNGs — immutable, cache forever
/pngs/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Engine — cache for a day, then revalidate
/specimen-engine.js
  Cache-Control: public, max-age=86400, must-revalidate

# HTML — cache for an hour
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

# Static brand assets
/og-image.png
  Cache-Control: public, max-age=86400

/favicon.svg
  Cache-Control: public, max-age=604800

/sitemap.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=86400
