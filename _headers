# preview.html — the NFT animation_url target. Must stay iframable from
# any origin so OpenSea + marketplaces + explorers can embed it. The
# wildcard /* rule above defaults frame-ancestors to 'none'; this block
# overrides the full CSP for this path to swap that for 'frame-ancestors *'.
# Per CF Pages docs, per-path headers REPLACE same-named headers from
# the wildcard, so we restate the full CSP line below — leaving anything
# off would lose script-src 'unsafe-inline' and other defences.
#
# X-Frame-Options is reset to ALLOWALL: a non-standard but widely-honored
# permissive value. Modern browsers prefer CSP frame-ancestors anyway,
# so XFO is belt + braces. Without resetting it, the wildcard's DENY
# would propagate and break embedding regardless of CSP.
/preview.html
  # Per-path overrides ADD to the wildcard headers in CF Pages — they
  # don't replace. So we need explicit `! Header-Name` lines to remove
  # the wildcard's frame-ancestors/X-Frame-Options FIRST, then set our
  # permissive versions. Without the `!` lines the browser ANDs both
  # CSPs and frame-ancestors 'none' wins (since 'none' is more
  # restrictive than '*'), breaking OpenSea's iframe of animation_url.
  #
  # NOTE: the index hero iframe loads `preview.html` directly. CF Pages
  # 308-redirects /preview.html → /preview, and the BROWSER follows the
  # redirect using the FINAL URL's headers — so the /preview block
  # below has to carry the same permissive CSP. The Cache-Control
  # entry for /preview that used to live further down was REPLACING
  # this whole block (CF Pages uses the last matching rule), which
  # silently re-enforced frame-ancestors 'none' and broke the hero.
  # All /preview rules now live here, single block.
  ! Content-Security-Policy
  ! X-Frame-Options
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' https://pngs.thebioms.com data: blob:; connect-src 'self' https://api.thebioms.com; font-src 'self' data:; media-src 'self' https://pngs.thebioms.com; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors *; upgrade-insecure-requests
  Cache-Control: public, max-age=60, must-revalidate
/preview
  ! Content-Security-Policy
  ! X-Frame-Options
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' https://pngs.thebioms.com data: blob:; connect-src 'self' https://api.thebioms.com; font-src 'self' data:; media-src 'self' https://pngs.thebioms.com; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors *; upgrade-insecure-requests
  Cache-Control: public, max-age=60, must-revalidate

# glass-500 — the Luoms renderer. Framed same-origin by / (the gate) and
# /luoms, and potentially by marketplaces if a live animation_url is ever
# used — so it gets the same permissive frame-ancestors treatment as
# /preview. No wallet flows or user input on this page, so the
# clickjacking concern that motivates the default 'none' doesn't apply.
# Same consolidation rule as /preview: ALL headers for the path live in
# this ONE block (CF Pages last-matching-rule semantics).
/glass-500.html
  ! Content-Security-Policy
  ! X-Frame-Options
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' https://pngs.thebioms.com data: blob:; connect-src 'self' https://api.thebioms.com; font-src 'self' data:; media-src 'self' https://pngs.thebioms.com; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors *; upgrade-insecure-requests
  Cache-Control: public, max-age=60, must-revalidate
/glass-500
  ! Content-Security-Policy
  ! X-Frame-Options
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' https://pngs.thebioms.com data: blob:; connect-src 'self' https://api.thebioms.com; font-src 'self' data:; media-src 'self' https://pngs.thebioms.com; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors *; upgrade-insecure-requests
  Cache-Control: public, max-age=60, must-revalidate

# Three.js vendored module — content only changes when we bump the vendored
# version, so cache a day + revalidate like the other shared JS.
/vendor/three.module.js
  Cache-Control: public, max-age=86400, must-revalidate

# Metadata JSON — short cache so mutations can refresh quickly (Phase 2)
# CORS open so OpenSea / marketplaces / explorers can fetch.
/metadata/*
  Cache-Control: public, max-age=300, s-maxage=300
  Access-Control-Allow-Origin: *

# Token PNGs / thumbs — immutable, cache forever.
# Thumbs (pngs/thumb/*) are 600×600 WebP+PNG, served by Pages directly.
# Masters (pngs/preview/*) are 3000×3000 PNGs, served by R2.
/pngs/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Engine — cache for a day, then revalidate
/specimen-engine.js
  Cache-Control: public, max-age=86400, must-revalidate

# Nav-wallet shared chrome (CSS+JS) — cache day, revalidate.
# Version-bust via ?v= query param when contents change.
/nav-wallet.css
  Cache-Control: public, max-age=86400, must-revalidate
/nav-wallet.js
  Cache-Control: public, max-age=86400, must-revalidate

# Design tokens (radii/shadows/easing/button system) — cache like nav-wallet.
# Version-bust via ?v= query param when contents change.
/design.css
  Cache-Control: public, max-age=86400, must-revalidate

# HTML — cache for an hour.
# Cloudflare Pages serves both /lab and /lab.html for the same file, but the
# _headers wildcard /*.html only matches the .html-suffixed form. The
# extensionless canonical URLs (the ones we ACTUALLY link from nav menus
# and the ones Twitter shares) need their own entries — without these the
# CDN serves them as cf-cache-status: DYNAMIC and every visitor hits the
# origin. With 10k+ visitors from a drop announcement, that's a brittle
# default. One-hour cache + must-revalidate means edge serves cached copy
# instantly but checks origin on each request for freshness (cheap 304s).
/*.html
  Cache-Control: public, max-age=60, must-revalidate
/
  Cache-Control: public, max-age=60, must-revalidate
/lab
  Cache-Control: public, max-age=60, must-revalidate
/bioms
  Cache-Control: public, max-age=60, must-revalidate
/luoms
  Cache-Control: public, max-age=60, must-revalidate
/explore
  Cache-Control: public, max-age=60, must-revalidate
/activity
  Cache-Control: public, max-age=60, must-revalidate
/manifesto
  Cache-Control: public, max-age=60, must-revalidate
/make
  Cache-Control: public, max-age=60, must-revalidate
/view
  Cache-Control: public, max-age=60, must-revalidate
# /preview Cache-Control moved into the consolidated /preview block
# above (security overrides + Cache-Control together) — having it here
# was creating a second matching rule that REPLACED the security block.
/unrevealed
  Cache-Control: public, max-age=60, must-revalidate
/soup
  Cache-Control: public, max-age=60, must-revalidate

# 404 explicitly NOT cached — without this, /*.html catches /404.html
# with a 1-hour cache, which means after a redeploy that adds a new
# real page, the CDN may keep serving the old 404 for legitimate URLs.
# `must-revalidate` forces the CDN to ask the origin every time.
/404.html
  Cache-Control: no-cache, must-revalidate
/404
  Cache-Control: no-cache, must-revalidate

# Admin panel — never cached, never indexed, never framed.
# Token lives in localStorage + URL hash, not in headers or logs.
/admin
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/admin.html
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY

# Internal render-compare tool — not linked, never indexed. Embeds
