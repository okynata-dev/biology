# Cloudflare Pages — HTTP headers
# https://developers.cloudflare.com/pages/configuration/headers/
#
# Frame-embedding policy:
#   preview.html + rare-*.html ARE the NFT animation_url targets —
#     OpenSea and other marketplaces must iframe them from any origin,
#     so frame-ancestors stays open there.
#   Everything else (lab.html, index.html, make.html, explore.html)
#     hosts wallet flows + user input → frame-ancestors 'none' so
#     attacker sites can't overlay an invisible "Connect → Sign"
#     clickjack sequence on top of our buttons.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# Lab + landing + make + explore — no third-party framing allowed.
# Cloudflare Pages serves both /lab and /lab.html — we list BOTH because
# _headers rules match by exact path string (no .html-stripping logic).
# Without the extensionless entries, the canonical URLs users visit
# (/lab, /make, /explore, etc.) would slip through with only the wildcard
# rules above.
/
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/index.html
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/lab
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/lab.html
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/make
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/make.html
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/explore
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/explore.html
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/manifesto
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/manifesto.html
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/reserve
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/reserve.html
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/404
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/404.html
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY

# Metadata JSON — short cache so mutations can refresh quickly (Phase 2)
# CORS open so OpenSea / marketplaces / explorers can fetch.
/metadata/*
  Cache-Control: public, max-age=300, s-maxage=300
  Access-Control-Allow-Origin: *

# Token PNGs / thumbs — immutable, cache forever.
# Thumbs (pngs/thumb/*) are 600×600 WebP+PNG, served by Pages directly.
# Masters (pngs/preview/*) are 3000×3000 PNGs, served by R2.
/pngs/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Engine — cache for a day, then revalidate
/specimen-engine.js
  Cache-Control: public, max-age=86400, must-revalidate

# HTML — cache for an hour
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

# Static brand assets
/og-image.png
  Cache-Control: public, max-age=86400

/favicon.svg
  Cache-Control: public, max-age=604800

/sitemap.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=86400
