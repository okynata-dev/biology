# Cloudflare Pages — HTTP headers
# https://developers.cloudflare.com/pages/configuration/headers/
#
# Frame-embedding policy:
#   preview.html IS the NFT animation_url target — OpenSea and other
#     marketplaces must iframe it from any origin, so frame-ancestors
#     stays open there.
#   Everything else (lab.html, index.html, make.html, explore.html,
#     gallery.html) hosts wallet flows + user input → frame-ancestors
#     'none' so attacker sites can't overlay an invisible "Connect →
#     Sign" clickjack sequence on top of our buttons.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=(), camera=(), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  # Baseline Content-Security-Policy applied to every response.
  #
  # frame-ancestors 'none' is the DEFAULT here as of 2026-05-28. Previous
  # arrangement put it only on per-path rules (/lab, /reserve, etc),
  # which turned out to work for the .html variants only — Cloudflare
  # Pages' header-matching for extensionless canonical URLs (the ones
  # users actually visit and we link from nav) silently fell through to
  # the wildcard, leaving /lab, /reserve, /, /make, /explore framable
  # by any origin. Clickjacking-the-connect-wallet was the worst case.
  #
  # Default deny here + a per-path override on the preview.html / preview
  # paths (which MUST stay iframable so OpenSea can embed them as the
  # token animation_url).
  # Those overrides live further down — search for "frame-ancestors *".
  #
  # 'unsafe-inline' on script-src / style-src is unavoidable until we
  # add a build step (every page uses inline <script> + <style> by
  # deliberate design — see CLAUDE.md §7). No 'unsafe-eval', no remote
  # scripts: in practice the attack surface left is XSS via injected
  # inline content, which the input validation in worker.js + the
  # absence of innerHTML-from-untrusted-data in the renderer mitigate.
  #
  # connect-src is whitelisted to the API origin only — Alchemy/OpenSea
  # are reached server-side via the worker, never directly from the
  # browser, so they don't need to appear here.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' https://pngs.thebioms.com data: blob:; connect-src 'self' https://api.thebioms.com; font-src 'self' data:; media-src 'self' https://pngs.thebioms.com; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests
  X-Frame-Options: DENY

# Lab + landing + make + explore — no third-party framing allowed.
# Cloudflare Pages serves both /lab and /lab.html — we list BOTH because
# _headers rules match by exact path string (no .html-stripping logic).
# Without the extensionless entries, the canonical URLs users visit
# (/lab, /make, /explore, etc.) would slip through with only the wildcard
# rules above.
/
  Content-Security-Policy: frame-ancestors 'none'
  X-Frame-Options: DENY
/index.html
